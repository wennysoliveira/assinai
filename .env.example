# ── Banco de dados (obrigatório) ──────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# ── Segurança da sessão (obrigatório) ────────────────────────────
# Gere uma string aleatória: openssl rand -hex 32
SESSION_SECRET=coloque_aqui_uma_string_secreta_longa

# ── Usuário administrador (obrigatório) ──────────────────────────
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=sua_senha_admin

# ── Integração PIX via QQPag (opcional) ──────────────────────────
QQPAG_BASE_URL=https://api.qqpag.com
QQPAG_TOKEN=seu_token_qqpag

# ── Integração WhatsApp via UazAPI (opcional) ─────────────────────
UAZAPI_BASE_URL=https://sua_instancia.uazapi.com
UAZAPI_TOKEN=seu_token_uazapi

# ── Nível de log (opcional, padrão: info) ────────────────────────
LOG_LEVEL=info
